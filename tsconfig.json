{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "paths": {
      "openclaw/plugin-sdk": ["../openclaw/src/plugin-sdk/index.ts"],
      "openclaw/plugin-sdk/*": ["../openclaw/src/plugin-sdk/*.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
